---
// src/islands/ContactModal.astro
// Island #3 (F-04, D-10). Native <dialog> + showModal() gives platform focus containment
// and Esc-close; this island additionally returns focus to the triggering "Hire me"
// button on close and sets aria-labelledby to the modal heading. The Turnstile widget
// script (the SOLE permitted third-party script, F-10.4) is injected LAZILY on first open
// using PUBLIC_TURNSTILE_SITE_KEY, so it never counts against initial JS (D-10). On
// submit it POSTs JSON to /api/contact per the request contract and shows a generic
// success/error state. The <script> is Astro-processed → external module (D-3, CSP-clean).
import site from '../config/site';
---

<dialog
  id="contact-modal"
  aria-labelledby="contact-modal-title"
  data-turnstile-sitekey={site.turnstileSiteKey}
  class="m-auto w-[min(92vw,32rem)] rounded-2xl border border-[var(--color-border)] bg-[var(--color-card)] p-0 text-[var(--color-ink)] backdrop:bg-black/50"
>
  <form id="contact-form" method="dialog" class="flex flex-col gap-4 p-6">
    <div class="flex items-start justify-between gap-4">
      <h2 id="contact-modal-title" class="text-lg font-bold tracking-tight">
        Hire me
      </h2>
      <button
        type="button"
        data-contact-close
        aria-label="Close contact form"
        class="rounded-lg p-1 text-[var(--color-ink-muted)] transition-colors hover:bg-[var(--color-surface-muted)]"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          aria-hidden="true"
        >
          <path d="M18 6 6 18M6 6l12 12"></path>
        </svg>
      </button>
    </div>

    <label class="flex flex-col gap-1 text-sm font-medium">
      Name
      <input
        type="text"
        name="name"
        required
        minlength="1"
        maxlength="100"
        autocomplete="name"
        class="rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] px-3 py-2 text-base"
      />
    </label>

    <label class="flex flex-col gap-1 text-sm font-medium">
      Your email
      <input
        type="email"
        name="email"
        required
        maxlength="254"
        autocomplete="email"
        class="rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] px-3 py-2 text-base"
      />
    </label>

    <label class="flex flex-col gap-1 text-sm font-medium">
      Message
      <textarea
        name="message"
        required
        minlength="10"
        maxlength="3000"
        rows="4"
        class="rounded-lg border border-[var(--color-border)] bg-[var(--color-surface)] px-3 py-2 text-base"
      ></textarea>
    </label>

    <!-- Honeypot: hidden from humans, off the tab order; bots that fill it get a silent
         200 with NO email sent (F-04.8, D-7). Not a security control on its own. -->
    <div aria-hidden="true" class="absolute left-[-9999px] h-0 w-0 overflow-hidden">
      <label>
        Website
        <input type="text" name="website" tabindex="-1" autocomplete="off" />
      </label>
    </div>

    <!-- Turnstile mounts here (lazy, on first open). -->
    <div id="turnstile-container"></div>

    <p
      id="contact-status"
      role="status"
      aria-live="polite"
      class="min-h-[1.25rem] text-sm text-[var(--color-ink-muted)]"
    >
    </p>

    <button
      type="submit"
      id="contact-submit"
      class="rounded-xl bg-[var(--color-brand-600)] px-5 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-[var(--color-brand-700)] disabled:opacity-60"
    >
      Send message
    </button>
  </form>
</dialog>

<script>
  // Island script: bundled to an external module by Astro (no inline body, D-3).
  // Turnstile global (loaded lazily on first open).
  interface TurnstileApi {
    render: (
      el: HTMLElement,
      opts: {
        sitekey: string;
        callback: (token: string) => void;
        'expired-callback'?: () => void;
        'error-callback'?: () => void;
      },
    ) => string;
    reset: (id?: string) => void;
  }

  const TURNSTILE_SRC = 'https://challenges.cloudflare.com/turnstile/v0/api.js';

  function init(): void {
    const dialog = document.getElementById('contact-modal') as HTMLDialogElement | null;
    if (!dialog) return;
    const form = document.getElementById('contact-form') as HTMLFormElement | null;
    const status = document.getElementById('contact-status');
    const submitBtn = document.getElementById('contact-submit') as HTMLButtonElement | null;
    const container = document.getElementById('turnstile-container');
    const siteKey = dialog.getAttribute('data-turnstile-sitekey') ?? '';

    let lastTrigger: HTMLElement | null = null;
    let turnstileToken = '';
    let turnstileWidgetId: string | null = null;
    let turnstileLoading = false;

    function setStatus(msg: string): void {
      if (status) status.textContent = msg;
    }

    function loadTurnstile(): void {
      if (!siteKey || !container || turnstileLoading || turnstileWidgetId) return;
      turnstileLoading = true;
      const render = (): void => {
        const ts = (window as unknown as { turnstile?: TurnstileApi }).turnstile;
        if (!ts || !container) return;
        turnstileWidgetId = ts.render(container, {
          sitekey: siteKey,
          callback: (token: string) => {
            turnstileToken = token;
          },
          'expired-callback': () => {
            turnstileToken = '';
          },
          'error-callback': () => {
            turnstileToken = '';
          },
        });
      };
      if ((window as unknown as { turnstile?: TurnstileApi }).turnstile) {
        render();
        return;
      }
      const script = document.createElement('script');
      script.src = TURNSTILE_SRC;
      script.async = true;
      script.defer = true;
      script.addEventListener('load', render);
      document.head.appendChild(script);
    }

    function open(trigger: HTMLElement | null): void {
      lastTrigger = trigger;
      setStatus('');
      dialog!.showModal();
      loadTurnstile();
    }

    function close(): void {
      if (dialog!.open) dialog!.close();
      // Return focus to the triggering "Hire me" button (D-10, F-08.2).
      if (lastTrigger && typeof lastTrigger.focus === 'function') {
        lastTrigger.focus();
      }
    }

    // Any [data-contact-open] trigger (Topbar + Hero CTAs) opens the modal.
    document.querySelectorAll<HTMLElement>('[data-contact-open]').forEach((el) => {
      el.addEventListener('click', () => open(el));
    });

    dialog.querySelectorAll<HTMLElement>('[data-contact-close]').forEach((el) => {
      el.addEventListener('click', () => close());
    });

    // Native <dialog> 'close' (incl. Esc) — restore focus to the trigger.
    dialog.addEventListener('close', () => {
      if (lastTrigger && typeof lastTrigger.focus === 'function') lastTrigger.focus();
    });

    form?.addEventListener('submit', async (e: SubmitEvent) => {
      e.preventDefault();
      if (!form) return;
      const data = new FormData(form);
      const payload = {
        name: String(data.get('name') ?? ''),
        email: String(data.get('email') ?? ''),
        message: String(data.get('message') ?? ''),
        website: String(data.get('website') ?? ''),
        turnstileToken,
      };

      if (submitBtn) submitBtn.disabled = true;
      setStatus('Sending…');
      try {
        const res = await fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        if (res.ok) {
          setStatus('Thanks — your message has been sent.');
          form.reset();
        } else if (res.status === 429) {
          setStatus('Too many attempts. Please try again later.');
        } else if (res.status === 403) {
          setStatus('Verification failed. Please retry the challenge.');
        } else {
          setStatus('Sorry, something went wrong. Please try again.');
        }
      } catch {
        setStatus('Network error. Please try again.');
      } finally {
        if (submitBtn) submitBtn.disabled = false;
        const ts = (window as unknown as { turnstile?: TurnstileApi }).turnstile;
        if (ts && turnstileWidgetId) {
          ts.reset(turnstileWidgetId);
          turnstileToken = '';
        }
      }
    });
  }

  init();
  document.addEventListener('astro:after-swap', init);
</script>
