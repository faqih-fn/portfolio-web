---
// src/pages/404.astro — Not-found page (T4). Static; uses the shared BaseLayout so the
// topbar/footer landmarks and theme are consistent. Cloudflare Pages serves this for
// unmatched routes from the static build.
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Page not found"
  description="The page you were looking for could not be found."
>
  <section class="mx-auto flex max-w-3xl flex-col items-center px-4 py-24 text-center">
    <p class="text-sm font-semibold uppercase tracking-widest text-[var(--color-brand-600)]">
      404
    </p>
    <h1 class="mt-3 text-4xl font-bold tracking-tight text-[var(--color-ink)] sm:text-5xl">
      Page not found
    </h1>
    <p class="mt-4 max-w-md text-base text-[var(--color-ink-muted)]">
      The page you were looking for doesn't exist or may have moved.
    </p>
    <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
      <a
        href="/"
        class="lift rounded-xl bg-[var(--color-brand-600)] px-5 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-[var(--color-brand-700)]"
      >
        Back to Dashboard
      </a>
      <a
        href="/projects"
        class="lift rounded-xl border border-[var(--color-border)] bg-[var(--color-card)] px-5 py-2.5 text-sm font-semibold text-[var(--color-ink)] transition-colors hover:bg-[var(--color-surface-muted)]"
      >
        View Projects
      </a>
    </div>
  </section>
</BaseLayout>
