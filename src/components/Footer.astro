---
// src/components/Footer.astro
// Footer: GitHub + GitLab + LinkedIn icon links ONLY (brief §5, AGENTS.md §7).
// No email address and no email-protocol links anywhere. GitLab links to gitlab.com only (baseline §3d).
import site from '../config/site';

const githubUrl = `https://github.com/${site.githubUsername}`;
const gitlabUrl = site.gitlabUsername
  ? `https://gitlab.com/${site.gitlabUsername}`
  : null;
const year = new Date().getFullYear();
---

<footer class="mt-16 border-t border-[var(--color-border)]">
  <div
    class="mx-auto flex max-w-5xl flex-col items-center gap-4 px-4 py-8 sm:flex-row sm:justify-between"
  >
    <p class="text-sm text-[var(--color-ink-muted)]">
      &copy; {year} {site.ownerName}
    </p>

    <ul class="flex items-center gap-4">
      <li>
        <a
          href={githubUrl}
          rel="me noopener noreferrer"
          target="_blank"
          aria-label="GitHub profile"
          class="text-[var(--color-ink-muted)] transition-colors hover:text-[var(--color-brand-600)]"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="22"
            height="22"
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
          >
            <path
              d="M12 .5C5.73.5.5 5.73.5 12.04c0 5.1 3.29 9.42 7.86 10.95.58.11.79-.25.79-.56 0-.28-.01-1.02-.02-2-3.2.7-3.87-1.54-3.87-1.54-.53-1.34-1.29-1.7-1.29-1.7-1.05-.72.08-.7.08-.7 1.16.08 1.77 1.2 1.77 1.2 1.03 1.78 2.71 1.27 3.37.97.1-.75.4-1.27.73-1.56-2.55-.29-5.24-1.28-5.24-5.7 0-1.26.45-2.29 1.19-3.1-.12-.29-.52-1.46.11-3.05 0 0 .97-.31 3.18 1.18a11 11 0 0 1 5.8 0c2.2-1.49 3.17-1.18 3.17-1.18.63 1.59.23 2.76.11 3.05.74.81 1.19 1.84 1.19 3.1 0 4.43-2.69 5.41-5.25 5.69.41.36.78 1.06.78 2.14 0 1.55-.01 2.8-.01 3.18 0 .31.21.68.8.56A11.53 11.53 0 0 0 23.5 12.04C23.5 5.73 18.27.5 12 .5Z"
            ></path>
          </svg>
        </a>
      </li>
      {
        gitlabUrl && (
          <li>
            <a
              href={gitlabUrl}
              rel="me noopener noreferrer"
              target="_blank"
              aria-label="GitLab profile"
              class="text-[var(--color-ink-muted)] transition-colors hover:text-[var(--color-brand-600)]"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="22"
                height="22"
                viewBox="0 0 24 24"
                fill="currentColor"
                aria-hidden="true"
              >
                <path d="M12 21.42 8.69 11.2H15.3L12 21.42ZM3.6 11.2l-1 3.1a.7.7 0 0 0 .25.78L12 21.42 3.6 11.2Zm5.09 0L12 21.42 5.74 2.95a.34.34 0 0 0-.65 0L3.6 11.2h5.09Zm11.71 0H15.3L12 21.42l8.4-6.34a.7.7 0 0 0 .25-.78l-1-3.1Zm0 0-1.49-8.25a.34.34 0 0 0-.65 0L15.3 11.2h5.1Z" />
              </svg>
            </a>
          </li>
        )
      }
      <li>
        <a
          href={site.linkedinUrl}
          rel="me noopener noreferrer"
          target="_blank"
          aria-label="LinkedIn profile"
          class="text-[var(--color-ink-muted)] transition-colors hover:text-[var(--color-brand-600)]"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="22"
            height="22"
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
          >
            <path
              d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.35V9h3.41v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.45v6.29ZM5.34 7.43a2.06 2.06 0 1 1 0-4.13 2.06 2.06 0 0 1 0 4.13ZM7.12 20.45H3.56V9h3.56v11.45ZM22.22 0H1.77C.79 0 0 .77 0 1.73v20.54C0 23.22.79 24 1.77 24h20.45c.98 0 1.78-.78 1.78-1.73V1.73C24 .77 23.2 0 22.22 0Z"
            ></path>
          </svg>
        </a>
      </li>
    </ul>
  </div>
</footer>
